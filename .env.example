# HIMS environment configuration — copy to .env / set as service env vars.
# Secrets (HIMS_ENCRYPTION_KEY) must NEVER be committed or logged.

# Postgres connection for the API + collector + migrator.
HIMS_DATABASE_URL=postgres://hims:hims@localhost:5433/hims?sslmode=disable

# AES-256 key (base64, 32 bytes) for encrypting credential secrets at rest.
# Generate once:  hims-api will refuse credential writes until this is set.
# Back this up OFF-BOX — encrypted secrets are unrecoverable without it.
HIMS_ENCRYPTION_KEY=

# API listen address.
HIMS_ADDR=:8090

# NetFlow v5 collector listen address (UDP). Empty/invalid disables it.
HIMS_NETFLOW_ADDR=:2055
# NetFlow aggregate flush interval (seconds).
HIMS_NETFLOW_FLUSH=60

# Environment label shown in System Health.
HIMS_ENV=production

# Bootstrap admin (Production Readiness P1 auth). On first run, when no user has
# a password yet, these create/adopt an admin account (full permissions) and
# activate login enforcement. Safe to leave set; ignored once any password
# exists. Change the password immediately after first login.
HIMS_ADMIN_USER=admin
HIMS_ADMIN_PASSWORD=
