<#
  HIMS Relay Agent — Windows installer
  Agent : {{.AgentName}}
  Site  : {{.SiteName}}
  HIMS  : {{.URL}}
  Built : {{.Version}}

  This package was generated by HIMS for ONE agent. It contains a registration
  token and is sensitive until installed — store it like a password and delete
  the package from shared locations once the agent is online.

  Usage (run as Administrator):
    Interactive : right-click install.cmd  →  Run as administrator
    Silent      : install.cmd /silent
    Repair      : powershell -ExecutionPolicy Bypass -File .\Install-HIMSRelayAgent.ps1 -Repair
    Uninstall   : powershell -ExecutionPolicy Bypass -File .\Install-HIMSRelayAgent.ps1 -Uninstall

  No build tools, Go, or manual editing are required.
#>
[CmdletBinding()]
param(
  [switch] $Silent,
  [switch] $Repair,
  [switch] $Uninstall,
  [string] $InstallDir = (Join-Path $env:ProgramFiles 'HIMS Relay Agent')
)

$ErrorActionPreference = 'Stop'

# --- baked configuration (generated by HIMS) --------------------------------
$HimsUrl     = '{{.URL}}'
$Token       = '{{.Token}}'
$AgentName   = '{{.AgentName}}'
$ServiceName = '{{.ServiceName}}'
$DisplayName = '{{.DisplayName}}'
$Version     = '{{.Version}}'
$ExeName     = '{{.ExeName}}'
$InsecureTls = '{{.InsecureTLS}}'   # "1" to accept a self-signed HIMS certificate
$LogDir      = Join-Path $env:ProgramData 'HIMS\RelayAgent\logs'

function Write-Step($m) { Write-Host "==> $m" -ForegroundColor Cyan }
function Write-Ok($m)   { Write-Host "  [ok] $m" -ForegroundColor Green }
function Write-Warn2($m){ Write-Host "  [!]  $m" -ForegroundColor Yellow }
function Write-Err2($m) { Write-Host "  [x]  $m" -ForegroundColor Red }

function Assert-Admin {
  $id = [Security.Principal.WindowsIdentity]::GetCurrent()
  $p  = New-Object Security.Principal.WindowsPrincipal($id)
  if (-not $p.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {
    throw 'This installer must be run as Administrator. Right-click install.cmd and choose "Run as administrator".'
  }
}

function Remove-Service-IfPresent {
  $svc = Get-Service -Name $ServiceName -ErrorAction SilentlyContinue
  if ($svc) {
    Write-Step "Removing existing service '$ServiceName'"
    if ($svc.Status -ne 'Stopped') { Stop-Service -Name $ServiceName -Force -ErrorAction SilentlyContinue }
    & sc.exe delete $ServiceName | Out-Null
    Start-Sleep -Seconds 1
    Write-Ok 'previous service removed'
  }
}

function Do-Uninstall {
  Assert-Admin
  Write-Host "Uninstalling HIMS Relay Agent ($AgentName)..." -ForegroundColor Cyan
  Remove-Service-IfPresent
  foreach ($v in 'HIMS_URL','HIMS_AGENT_TOKEN','HIMS_AGENT_NAME','HIMS_AGENT_INSECURE_TLS','HIMS_AGENT_LOG_DIR') {
    [Environment]::SetEnvironmentVariable($v, $null, 'Machine')
  }
  if (Test-Path $InstallDir) { Remove-Item -Recurse -Force $InstallDir -ErrorAction SilentlyContinue }
  Write-Ok 'service removed, machine environment cleaned, files deleted'
  Write-Host "Done. The agent will show offline in HIMS until re-installed." -ForegroundColor Green
}

function Test-HimsReachable {
  try {
    $u = [Uri]$HimsUrl
    $port = if ($u.Port -gt 0) { $u.Port } elseif ($u.Scheme -eq 'https') { 443 } else { 80 }
    $r = Test-NetConnection -ComputerName $u.Host -Port $port -WarningAction SilentlyContinue
    if ($r.TcpTestSucceeded) { Write-Ok "HIMS reachable at $($u.Host):$port" }
    else { Write-Warn2 "Could not reach HIMS at $($u.Host):$port — the agent will keep retrying once installed." }
  } catch { Write-Warn2 "Reachability check skipped: $($_.Exception.Message)" }
}

function Do-Install {
  Assert-Admin
  Write-Host "Installing HIMS Relay Agent $Version" -ForegroundColor Cyan
  Write-Host "  Agent : $AgentName"
  Write-Host "  Site  : {{.SiteName}}"
  Write-Host "  HIMS  : $HimsUrl"
  Write-Host "  Dir   : $InstallDir"
  if (-not $Silent -and -not $Repair) {
    $ans = Read-Host 'Proceed with installation? (Y/N)'
    if ($ans -notmatch '^(y|yes)$') { Write-Host 'Cancelled.'; return }
  }

  Write-Step 'Checking connectivity to HIMS'
  Test-HimsReachable

  Write-Step 'Installing files'
  New-Item -ItemType Directory -Force -Path $InstallDir | Out-Null
  New-Item -ItemType Directory -Force -Path $LogDir | Out-Null
  $src = Join-Path $PSScriptRoot $ExeName
  if (-not (Test-Path $src)) { throw "agent binary '$ExeName' not found next to this script." }
  $dst = Join-Path $InstallDir 'hims-agent.exe'
  Copy-Item -Path $src -Destination $dst -Force
  Write-Ok "agent copied to $dst"

  Write-Step 'Writing machine configuration'
  [Environment]::SetEnvironmentVariable('HIMS_URL', $HimsUrl, 'Machine')
  [Environment]::SetEnvironmentVariable('HIMS_AGENT_TOKEN', $Token, 'Machine')
  [Environment]::SetEnvironmentVariable('HIMS_AGENT_NAME', $AgentName, 'Machine')
  [Environment]::SetEnvironmentVariable('HIMS_AGENT_LOG_DIR', $LogDir, 'Machine')
  if ($InsecureTls -eq '1') { [Environment]::SetEnvironmentVariable('HIMS_AGENT_INSECURE_TLS', '1', 'Machine') }
  Write-Ok 'configuration stored (machine scope)'

  Remove-Service-IfPresent
  Write-Step "Registering Windows service '$DisplayName'"
  & sc.exe create $ServiceName binPath= "`"$dst`"" start= auto DisplayName= "$DisplayName" obj= LocalSystem | Out-Null
  & sc.exe description $ServiceName "HIMS Relay Agent / Site Collector ($AgentName) — version $Version" | Out-Null
  # Restart on failure: 5s, 5s, then every 30s; reset the counter daily.
  & sc.exe failure $ServiceName reset= 86400 actions= restart/5000/restart/5000/restart/30000 | Out-Null
  Write-Ok 'service registered (Automatic start, restart-on-failure)'

  Write-Step 'Starting service'
  & sc.exe start $ServiceName | Out-Null
  Start-Sleep -Seconds 2
  $svc = Get-Service -Name $ServiceName -ErrorAction SilentlyContinue
  if ($svc -and $svc.Status -eq 'Running') { Write-Ok 'service is Running' }
  else { Write-Warn2 "service state: $($svc.Status). Check $LogDir\agent.log" }

  Write-Step 'Validating agent registration (waiting up to 30s for first heartbeat)'
  $log = Join-Path $LogDir 'agent.log'
  $ok = $false
  for ($i = 0; $i -lt 15; $i++) {
    Start-Sleep -Seconds 2
    if (Test-Path $log) {
      $tail = Get-Content $log -Tail 20 -ErrorAction SilentlyContinue
      if ($tail -match 'registered as') { $ok = $true; break }
      if ($tail -match 'HTTP 401') { Write-Err2 'agent token was rejected (HTTP 401) — regenerate the token in HIMS and re-download the installer.'; break }
    }
  }
  if ($ok) {
    Write-Ok 'agent registered with HIMS — it should appear ONLINE in HIMS within ~30s'
  } else {
    Write-Warn2 "Could not confirm registration yet. The service keeps retrying. Inspect: $log"
  }

  Write-Host ''
  Write-Host 'Installation complete.' -ForegroundColor Green
  Write-Host "  Service : $DisplayName ($ServiceName) — manage via Services.msc"
  Write-Host "  Logs    : $LogDir\agent.log"
  Write-Host "  Version : $Version  (run `"$dst`" -version)"
  Write-Host "  Uninstall: powershell -ExecutionPolicy Bypass -File .\Install-HIMSRelayAgent.ps1 -Uninstall"
}

if ($Uninstall) { Do-Uninstall; return }
Do-Install
