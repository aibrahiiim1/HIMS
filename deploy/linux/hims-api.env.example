# HIMS API environment — copy to /etc/hims/hims-api.env, fill in, then:
#   sudo chown root:hims /etc/hims/hims-api.env && sudo chmod 0640 /etc/hims/hims-api.env
#
# This file is loaded by the systemd unit (EnvironmentFile=). Keep it 0640 so the
# encryption key is not world-readable. NEVER commit a filled-in copy to git.

# --- Required ---------------------------------------------------------------
# AES key for credential encryption-at-rest. Base64 of 32 random bytes, e.g.
#   openssl rand -base64 32
# The API REFUSES TO START if encrypted credentials already exist and this key
# is missing or wrong — keep an off-box backup of the exact value.
HIMS_ENCRYPTION_KEY=

# PostgreSQL DSN.
HIMS_DATABASE_URL=postgres://hims:hims@localhost:5432/hims?sslmode=disable

# --- Optional ---------------------------------------------------------------
# Listen address (host:port). Default :8090.
HIMS_ADDR=:8090

# Directory holding the prebuilt Relay Agent binaries the API serves to operators
# (stage with deploy/build-agents.sh). Default <dir-of-binary>/agents.
HIMS_AGENT_DIST_DIR=/opt/hims/agents

# Externally reachable base URL baked into generated agent installers.
# HIMS_PUBLIC_URL=https://hims.example.com

# Environment label shown in System Health.
HIMS_ENV=production

# First-run admin bootstrap (only used while no user has a password yet).
# HIMS_ADMIN_USER=admin
# HIMS_ADMIN_PASSWORD=change-me
