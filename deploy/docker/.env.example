# Copy to deploy/docker/.env and edit. Used by docker-compose.yml.
# NOTE: the encryption KEY is NOT here — it is a Docker secret file
# (hims_encryption_key.secret). See docker-compose.yml header.

# Postgres credentials for the bundled db service.
POSTGRES_USER=hims
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=hims

# Host port to expose the API on (container always listens on 8090).
HIMS_PORT=8090

# Environment label shown in System Health.
HIMS_ENV=production
